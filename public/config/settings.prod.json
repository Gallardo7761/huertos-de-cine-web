{
    "apiConfig": {
        "baseUrl": "https://api.miarma.net/v2/cine",
        "coreUrl": "https://api.miarma.net/v2/core",
        "endpoints": {
            "auth": {
                "login": "/auth/login",
                "refreshToken": "/auth/refresh",
                "changePassword": "/auth/change-password",
                "validateToken": "/auth/validate"
            },
            "viewers": {
                "all": "/viewers",
                "byId": "/viewers/:userId"
            },
            "movies": {
                "all": "/movies",
                "byId": "/movies/:movieId",
                "upvote": "/movies/:movieId/upvote",
                "downvote": "/movies/:movieId/downvote"
            },
            "requests": {
                "all": "/requests",
                "accept": "/requests/:requestId/accept",
                "reject": "/requests/:requestId/reject"
            }
        }
    }
}